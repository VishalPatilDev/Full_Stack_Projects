package com.project.e_commerce.service;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import com.project.e_commerce.dto.CartItemReqDto;
import com.project.e_commerce.entity.Cart;
import com.project.e_commerce.entity.CartItem;
import com.project.e_commerce.entity.Product;
import com.project.e_commerce.repository.CartItemRepository;
import com.project.e_commerce.repository.CartRepository;

@Service
public class CartServiceImpl implements CartService {
	@Autowired
    private CartRepository cartRepository;

    @Autowired
    private CartItemRepository cartItemRepository;

    
	@Override
	public CartItem addProductToCart(CartItemReqDto dto) {
		// 1. Get or create a default cart (you can modify for user-specific carts)
        Cart cart = cartRepository.findTopByOrderByIdAsc().orElseGet(() -> {
            Cart newCart = new Cart();
            return cartRepository.save(newCart);
        });

        // 2. Convert ProductReqDto → Product entity
        Product product = Product.builder()
                .productName(dto.getProductDto().getProductName())
                .productDescription(dto.getProductDto().getProductDescription())
                .productPrice(dto.getProductDto().getProductPrice())
                .productImage(dto.getProductDto().getProductImage())
                .build();

        // 3. Create CartItem
        CartItem cartItem = CartItem.builder()
                .product(product)
                .quantity(dto.getQuantity())
                .cart(cart)
                .build();

        // 4. Add item to cart
        cart.addItem(cartItem);

        // 5. Save cart item
        cartItemRepository.save(cartItem);

        return cartItem;
	}

}
